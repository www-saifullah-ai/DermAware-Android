<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- DermAware base theme — uses NoActionBar since Compose manages its own TopAppBar -->
    <style name="Theme.DermAware" parent="android:Theme.Material.Light.NoActionBar">
        <!-- Splash screen / window background color (matches our app background) -->
        <item name="android:windowBackground">@color/app_background</item>
        <!-- Edge-to-edge rendering -->
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
    </style>

    <!-- Splash screen theme — shown briefly on app launch with the app icon -->
    <style name="Theme.DermAware.Splash" parent="Theme.SplashScreen">
        <!-- App icon displayed in the center of the splash screen -->
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <!-- Teal background matching the brand color -->
        <item name="windowSplashScreenBackground">@color/primary_teal</item>
        <!-- Transition to the main app theme after splash completes -->
        <item name="postSplashScreenTheme">@style/Theme.DermAware</item>
    </style>
</resources>
